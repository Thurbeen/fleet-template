{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "root=$(git rev-parse --show-toplevel 2>/dev/null) && [ -x \"$root/scripts/sync-checkout.sh\" ] && bash \"$root/scripts/sync-checkout.sh\" || true",
            "timeout": 25,
            "statusMessage": "Syncing the control plane with origin..."
          }
        ]
      }
    ]
  }
}
